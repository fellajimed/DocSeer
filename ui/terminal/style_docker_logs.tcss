DockerLogsWidget {
    height: 100%;
    width: 100%;
    layout: vertical;
}

#log-search-bar {
    height: auto;
    width: 100%;
    padding: 0;
    background: $background;
    border-bottom: none;
}

#log-search {
    width: 1fr;
    border: tall $primary;
    background: $surface;
}

#docker-log {
    height: 1fr;
    padding: 0 1;
    scrollbar-gutter: stable;
    scrollbar-size: 1 1;
    background: $background;
}
