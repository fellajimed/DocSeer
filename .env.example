# DocSeer environment configuration
# Copy this file to .env and adjust values as needed.
# All DOCSEER_ variables are picked up by pydantic-settings (Settings class).

# ── LLM / embedding models ────────────────────────────────────────────────────
# These must be available in your Ollama instance.
# With DOCSEER_OLLAMA_PULL_ON_STARTUP=true (default), DocSeer pulls them
# automatically at startup if they are not already present locally.
DOCSEER_LLM_MODEL=qwen3.5:4b
DOCSEER_EMBEDDING_MODEL=nomic-embed-text
# Set to false to skip the pull step (e.g. air-gapped envs, pre-pulled images).
DOCSEER_OLLAMA_PULL_ON_STARTUP=true

# ── Native macOS Ollama (optional — recommended on Apple Silicon) ─────────────
# Running Ollama natively on macOS uses Apple Metal (GPU) instead of CPU-only
# Docker, giving 10-50x faster inference.
#
# Steps:
#   1. brew install ollama && ollama serve
#   2. make pull-models-native
#   3. make up-native   (instead of make up)
#      make run-native  (instead of make run)
#
# When using native mode the DOCSEER_OLLAMA_BASE_URL below is set automatically
# by docker-compose.native-ollama.yml to http://host.docker.internal:11434.
# You do NOT need to change it here unless running in a non-standard setup.

# ── retriever tuning ──────────────────────────────────────────────────────────
DOCSEER_RETRIEVER_TOPK=5
DOCSEER_RERANKER_MODEL=ms-marco-MultiBERT-L-12
DOCSEER_RERANKER_TOPK=5
DOCSEER_EMBEDDING_BATCH_SIZE=128

# ── chat streaming latency tuning ─────────────────────────────────────────────
# Lower values reduce first-token latency at the cost of less context.
DOCSEER_CHAT_CONTEXT_DOCS=2
DOCSEER_CHAT_MAX_CONTEXT_CHARS=6000
DOCSEER_CHAT_HISTORY_TURNS=4
DOCSEER_CHAT_MODEL_KEEP_ALIVE=30m
DOCSEER_CHAT_RETRIEVAL_TIMEOUT_SECONDS=2.5
# LLM generation — tune for speed vs quality.
# num_ctx:     KV-cache window in tokens. 20000 gives safe headroom for
#              large retrieved context + chat history + question.
# num_predict: max tokens per response (~4096 ≈ 3000 words).
# temperature: lower = more focused output and marginally faster generation.
DOCSEER_CHAT_NUM_CTX=20000
DOCSEER_CHAT_NUM_PREDICT=4096
DOCSEER_CHAT_TEMPERATURE=0.1

# ── service URLs (override only if you change port mappings) ──────────────────
# These defaults match the docker-compose.yaml service names and work inside
# the Docker network.  You only need to change them if running services
# outside of Docker.
DOCSEER_POSTGRES_URL=postgresql+asyncpg://docseer:docseer@postgres:5432/docseer
DOCSEER_POSTGRES_SYNC_URL=postgresql+psycopg2://docseer:docseer@postgres:5432/docseer
DOCSEER_REDIS_URL=redis://redis:6379/0
DOCSEER_CHROMA_HOST=chromadb
DOCSEER_CHROMA_PORT=8000
DOCSEER_OLLAMA_BASE_URL=http://ollama:11434
DOCSEER_GROBID_URL=http://grobid:8070
DOCSEER_ZOTERO_URL=http://zotero:1969

# ── storage ───────────────────────────────────────────────────────────────────
DOCSEER_DOCSTORE_PATH=/data/docstore

# ── TUI ───────────────────────────────────────────────────────────────────────
# URL the TUI uses to reach the API.  Inside Docker this is http://api:8000.
# Set to http://localhost:8000 when running the TUI outside Docker.
DOCSEER_API_URL=http://api:8000
